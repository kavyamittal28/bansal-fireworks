# MongoDB
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
DB_NAME=bansal_fireworks

# JWT
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,https://bansal-fireworks.vercel.app

# App
APP_ENV=development
